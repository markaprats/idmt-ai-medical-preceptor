{
  "universal_red_flags": [
    "Airway compromise",
    "Severe respiratory distress",
    "Hemodynamic instability",
    "Altered mental status",
    "Uncontrolled bleeding",
    "Severe pain out of proportion",
    "Rapid clinical deterioration",
    "Inability to obtain vital signs"
